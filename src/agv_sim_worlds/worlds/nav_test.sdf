<?xml version="1.0"?>
<sdf version="1.9">
  <world name="nav_test">

    <!-- Gz System Plugins -->
    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics">
    </plugin>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands">
    </plugin>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster">
    </plugin>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim-imu-system" name="gz::sim::systems::Imu">
    </plugin>
    <plugin filename="gz-sim-contact-system" name="gz::sim::systems::Contact">
    </plugin>

    <!-- Physics -->
    <physics name="default" type="dart">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <!-- Lighting -->
    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- Ground Plane -->
    <model name="ground_plane">
      <static>true</static>
      <link name="ground_link">
        <collision name="ground_collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>15 15</size>
            </plane>
          </geometry>
        </collision>
        <visual name="ground_visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>15 15</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.8 0.8 0.8 1</ambient>
            <diffuse>0.85 0.85 0.85 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ═══════════════ Outer Walls (~10m x 10m room) ═══════════════ -->
    <model name="wall_north">
      <static>true</static>
      <pose>5 5 1 0 0 0</pose>
      <link name="wall_link">
        <collision name="col"><geometry><box><size>10 0.2 2.0</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>10 0.2 2.0</size></box></geometry>
          <material><ambient>0.6 0.6 0.6 1</ambient><diffuse>0.7 0.7 0.7 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="wall_south">
      <static>true</static>
      <pose>5 -5 1 0 0 0</pose>
      <link name="wall_link">
        <collision name="col"><geometry><box><size>10 0.2 2.0</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>10 0.2 2.0</size></box></geometry>
          <material><ambient>0.6 0.6 0.6 1</ambient><diffuse>0.7 0.7 0.7 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="wall_west">
      <static>true</static>
      <pose>0 0 1 0 0 0</pose>
      <link name="wall_link">
        <collision name="col"><geometry><box><size>0.2 10 2.0</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>0.2 10 2.0</size></box></geometry>
          <material><ambient>0.6 0.6 0.6 1</ambient><diffuse>0.7 0.7 0.7 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="wall_east">
      <static>true</static>
      <pose>10 0 1 0 0 0</pose>
      <link name="wall_link">
        <collision name="col"><geometry><box><size>0.2 10 2.0</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>0.2 10 2.0</size></box></geometry>
          <material><ambient>0.6 0.6 0.6 1</ambient><diffuse>0.7 0.7 0.7 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ═══════════════ Internal walls creating corridors ═══════════════ -->
    <model name="divider_h">
      <static>true</static>
      <pose>5 0 1 0 0 0</pose>
      <link name="wall_link">
        <collision name="col"><geometry><box><size>6 0.2 2.0</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>6 0.2 2.0</size></box></geometry>
          <material><ambient>0.5 0.5 0.5 1</ambient><diffuse>0.6 0.6 0.6 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="divider_v">
      <static>true</static>
      <pose>3 2.5 1 0 0 0</pose>
      <link name="wall_link">
        <collision name="col"><geometry><box><size>0.2 4 2.0</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>0.2 4 2.0</size></box></geometry>
          <material><ambient>0.5 0.5 0.5 1</ambient><diffuse>0.6 0.6 0.6 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Start marker (visual only, green) -->
    <model name="start_marker">
      <static>true</static>
      <pose>2 -3 0.01 0 0 0</pose>
      <link name="marker_link">
        <visual name="vis"><geometry><box><size>0.5 0.5 0.01</size></box></geometry>
          <material><ambient>0.1 0.8 0.1 1</ambient><diffuse>0.1 0.9 0.1 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Goal marker (visual only, red) -->
    <model name="goal_marker">
      <static>true</static>
      <pose>8 3 0.01 0 0 0</pose>
      <link name="marker_link">
        <visual name="vis"><geometry><box><size>0.5 0.5 0.01</size></box></geometry>
          <material><ambient>0.8 0.1 0.1 1</ambient><diffuse>0.9 0.1 0.1 1</diffuse></material>
        </visual>
      </link>
    </model>

  </world>
</sdf>
