    <!-- ═══════════════ Heating Pipe Rails ═══════════════ -->
    <!-- 2 parallel steel pipes per aisle x 5 aisles = 10 rails -->
    <!-- 51mm diameter, 20m long, 450mm apart center-to-center -->

    <!-- Aisle 1-2 (Y = -4.4) -->
