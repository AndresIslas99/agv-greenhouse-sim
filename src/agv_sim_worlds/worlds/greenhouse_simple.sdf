<?xml version="1.0"?>
<sdf version="1.9">
  <world name="greenhouse_simple">

    <!-- ═══════════════ Gz System Plugins ═══════════════ -->
    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics">
    </plugin>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands">
    </plugin>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster">
    </plugin>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim-imu-system" name="gz::sim::systems::Imu">
    </plugin>
    <plugin filename="gz-sim-contact-system" name="gz::sim::systems::Contact">
    </plugin>

    <!-- ═══════════════ Physics ═══════════════ -->
    <physics name="default" type="dart">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <!-- ═══════════════ Lighting ═══════════════ -->
    <!-- Main sun — brighter for greenhouse interior -->
    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>1.0 1.0 0.95 1</diffuse>
      <specular>0.3 0.3 0.3 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- Fill light — reduces harsh shadows inside greenhouse -->
    <light type="directional" name="fill">
      <cast_shadows>false</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.4 0.4 0.45 1</diffuse>
      <specular>0.05 0.05 0.05 1</specular>
      <direction>0.5 -0.3 -0.7</direction>
    </light>

    <!-- Ambient bounce — simulates light scattered by polycarbonate walls -->
    <light type="directional" name="ambient_bounce">
      <cast_shadows>false</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.25 0.25 0.25 1</diffuse>
      <specular>0.0 0.0 0.0 1</specular>
      <direction>0.0 0.0 -1.0</direction>
    </light>

    <!-- ═══════════════ Ground Plane ═══════════════ -->
    <model name="ground_plane">
      <static>true</static>
      <pose>15 0 0 0 0 0</pose>
      <link name="ground_link">
        <collision name="ground_collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>34 19</size>
            </plane>
          </geometry>
        </collision>
        <visual name="ground_visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>34 19</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.25 0.2 0.12 1</ambient>
            <diffuse>0.35 0.28 0.16 1</diffuse>
            <specular>0.05 0.04 0.03 1</specular>
            <pbr><metal><albedo_map>model://textures/ground_soil.png</albedo_map><metalness>0.0</metalness><roughness>0.95</roughness></metal></pbr>
          </material>
        </visual>
      </link>
    </model>

    <!-- ═══════════════ Greenhouse Walls (~30m x 15m) ═══════════════ -->
    <!-- North wall -->
    <model name="wall_north">
      <static>true</static>
      <pose>15 7.5 1.5 0 0 0</pose>
      <link name="wall_link">
        <collision name="col"><geometry><box><size>30 0.2 3.0</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>30 0.2 3.0</size></box></geometry>
          <material>
            <ambient>0.85 0.88 0.85 0.85</ambient>
            <diffuse>0.9 0.93 0.9 0.85</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
            <pbr><metal><albedo_map>model://textures/wall_polycarbonate.png</albedo_map><metalness>0.0</metalness><roughness>0.85</roughness></metal></pbr>
          </material>
        </visual>
      </link>
    </model>

    <!-- South wall -->
    <model name="wall_south">
      <static>true</static>
      <pose>15 -7.5 1.5 0 0 0</pose>
      <link name="wall_link">
