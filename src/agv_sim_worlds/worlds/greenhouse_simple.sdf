      <static>true</static>
      <pose>16.0 -4.625 0.0255 0 1.5708 0</pose>
      <link name="rail_link">
        <collision name="col"><geometry><cylinder><radius>0.0255</radius><length>20.0</length></cylinder></geometry></collision>
