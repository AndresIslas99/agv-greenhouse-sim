<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ═══════════════════════════════════════════════════════ -->
  <!--  ZED 2i Stereo Camera — TF chain matching real ZED SDK -->
  <!-- ═══════════════════════════════════════════════════════ -->

  <!-- ZED camera body link (175mm x 30mm x 33mm) -->
  <link name="zed_camera_link">
    <visual>
      <geometry>
        <box size="0.175 0.030 0.033"/>
      </geometry>
      <material name="zed_dark_grey">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.175 0.030 0.033"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.16"/>
      <inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00005"/>
    </inertial>
  </link>

  <joint name="zed_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="zed_camera_link"/>
    <origin xyz="0.7 0.0 -0.055" rpy="0 0 0"/>
  </joint>

  <!-- Optical center between lenses (identity transform from camera body) -->
  <link name="zed_camera_center">
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>

  <joint name="zed_camera_center_joint" type="fixed">
    <parent link="zed_camera_link"/>
    <child link="zed_camera_center"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Left camera frame (+0.06m Y = half of 120mm baseline) -->
  <link name="zed_left_camera_frame">
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>

  <joint name="zed_left_camera_joint" type="fixed">
    <parent link="zed_camera_link"/>
    <child link="zed_left_camera_frame"/>
    <origin xyz="0.0 0.06 0.0" rpy="0 0 0"/>
  </joint>

  <!-- Left camera optical frame (rotated for optical convention: Z forward, X right, Y down) -->
  <link name="zed_left_camera_optical_frame">
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>

  <joint name="zed_left_camera_optical_joint" type="fixed">
    <parent link="zed_left_camera_frame"/>
    <child link="zed_left_camera_optical_frame"/>
    <!-- Rotate -90 deg around Z then -90 deg around X for optical convention -->
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

  <!-- Right camera frame (-0.06m Y = half of 120mm baseline) -->
  <link name="zed_right_camera_frame">
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>

  <joint name="zed_right_camera_joint" type="fixed">
    <parent link="zed_camera_link"/>
    <child link="zed_right_camera_frame"/>
    <origin xyz="0.0 -0.06 0.0" rpy="0 0 0"/>
  </joint>

  <!-- Right camera optical frame -->
  <link name="zed_right_camera_optical_frame">
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>

  <joint name="zed_right_camera_optical_joint" type="fixed">
    <parent link="zed_right_camera_frame"/>
    <child link="zed_right_camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

  <!-- IMU link (co-located with camera body) -->
  <link name="imu_link">
    <visual>
      <geometry>
        <box size="0.02 0.02 0.02"/>
      </geometry>
      <material name="imu_blue">
        <color rgba="0.0 0.0 0.8 1.0"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="zed_camera_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!--  Left Camera Sensor (RGB + Depth + PointCloud)          -->
  <!--  Gz Transport topics bridged to ROS via ros_gz_bridge   -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <gazebo reference="zed_left_camera_frame">
    <sensor type="depth_camera" name="zed_left_depth">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <topic>/zed_left</topic>
      <gz_frame_id>zed_left_camera_optical_frame</gz_frame_id>
      <camera>
        <horizontal_fov>1.9199</horizontal_fov>
        <image>
          <width>1280</width>
          <height>720</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.3</near>
          <far>20.0</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
      </camera>
    </sensor>
  </gazebo>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!--  Right Camera Sensor (RGB only)                         -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <gazebo reference="zed_right_camera_frame">
    <sensor type="camera" name="zed_right_camera">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <topic>/zed_right</topic>
      <gz_frame_id>zed_right_camera_optical_frame</gz_frame_id>
      <camera>
        <horizontal_fov>1.9199</horizontal_fov>
        <image>
          <width>1280</width>
          <height>720</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.3</near>
          <far>20.0</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
      </camera>
    </sensor>
  </gazebo>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!--  ZED 2i IMU — 400Hz, datasheet noise values             -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <gazebo reference="imu_link">
    <sensor name="zed_imu" type="imu">
      <always_on>true</always_on>
      <update_rate>400</update_rate>
      <topic>/zed_imu</topic>
      <gz_frame_id>imu_link</gz_frame_id>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>0.00279</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>0.00279</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>0.00279</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>0.0314</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>0.0314</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>0.0314</stddev></noise></z>
        </linear_acceleration>
      </imu>
    </sensor>
  </gazebo>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!--  2D Lidar (supplementary sensor)                        -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <link name="laser_frame">
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.04"/>
      </geometry>
      <material name="lidar_red">
        <color rgba="0.8 0.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.04" length="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00005"/>
    </inertial>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_frame"/>
    <origin xyz="0.5 0.0 0.10" rpy="0 0 0"/>
  </joint>

  <gazebo reference="laser_frame">
    <sensor name="lidar_sensor" type="gpu_lidar">
      <always_on>true</always_on>
      <visualize>false</visualize>
      <update_rate>10</update_rate>
      <topic>/lidar</topic>
      <gz_frame_id>laser_frame</gz_frame_id>
      <lidar>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159265359</min_angle>
            <max_angle>3.14159265359</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.1</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.005</stddev>
        </noise>
      </lidar>
    </sensor>
  </gazebo>

</robot>
