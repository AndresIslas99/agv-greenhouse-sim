<?xml version="1.0"?>
<!--
  AGV Simulation Robot Description

  All dimensions from src/agv_sim_description/config/robot_params.yaml
  Override via xacro args or launch parameters if needed.

  TF chain produced:
    base_link
      ├── left_wheel     (continuous joint, driven by Gazebo diff_drive)
      ├── right_wheel    (continuous joint, driven by Gazebo diff_drive)
      ├── base_footprint (fixed, at ground level)
      ├── zed_camera_link (fixed, at ZED 2i position)
      │    ├── zed_camera_center
      │    ├── zed_left_camera_frame → zed_left_camera_optical_frame
      │    ├── zed_right_camera_frame → zed_right_camera_optical_frame
      │    └── imu_link
      ├── laser_frame    (fixed, front-mounted)
      ├── front_caster   (fixed, for sim stability)
      └── rear_caster    (fixed, for sim stability)

  Gazebo plugins:
    - libgazebo_ros_diff_drive.so (reads shaped_cmd_vel from drive shaping node)
    - libgazebo_ros_camera.so (ZED 2i left: RGB + depth + point cloud)
    - libgazebo_ros_camera.so (ZED 2i right: RGB)
    - libgazebo_ros_imu_sensor.so (ZED 2i IMU at 400Hz)
    - libgazebo_ros_ray_sensor.so (2D lidar, supplementary)
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="agv">

  <!-- Measured parameters (defaults from robot_params.yaml, 2026-03-18) -->
  <xacro:arg name="wheel_radius"  default="0.0625"/>
  <xacro:arg name="left_wheel_y"  default="0.3675"/>
  <xacro:arg name="right_wheel_y" default="-0.3675"/>
  <xacro:arg name="wheel_z"       default="-0.1375"/>
  <xacro:arg name="wheel_width"   default="0.05"/>

  <!-- Diff drive TF control — set via launch arg for different modes -->
  <xacro:arg name="publish_odom_tf" default="false"/>

  <!-- Include components -->
  <xacro:include filename="$(find agv_sim_description)/urdf/agv_base_sim.xacro"/>
  <xacro:include filename="$(find agv_sim_description)/urdf/wheel_sim.xacro"/>
  <xacro:include filename="$(find agv_sim_description)/urdf/sensors_sim.xacro"/>

  <!-- Left wheel -->
  <xacro:wheel
    name="left"
    x="0"
    y="$(arg left_wheel_y)"
    z="$(arg wheel_z)"
    radius="$(arg wheel_radius)"
    width="$(arg wheel_width)"/>

  <!-- Right wheel -->
  <xacro:wheel
    name="right"
    x="0"
    y="$(arg right_wheel_y)"
    z="$(arg wheel_z)"
    radius="$(arg wheel_radius)"
    width="$(arg wheel_width)"/>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!--  Gazebo Diff-Drive Plugin                              -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <gazebo>
    <plugin name="diff_drive_controller" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <remapping>cmd_vel:=cmd_vel</remapping>
      </ros>

      <!-- Joints -->
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>

      <!-- Kinematics -->
      <wheel_separation>0.735</wheel_separation>
      <wheel_diameter>0.125</wheel_diameter>

      <!-- Limits -->
      <max_wheel_torque>20.0</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>

      <!-- Odometry output -->
      <publish_odom>true</publish_odom>
      <publish_odom_tf>$(arg publish_odom_tf)</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>

      <!-- Frames -->
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>

      <!-- Topics -->
      <command_topic>shaped_cmd_vel</command_topic>
      <odometry_topic>wheel_odom</odometry_topic>

      <!-- Rate -->
      <update_rate>50.0</update_rate>
    </plugin>
  </gazebo>

</robot>
