<?xml version="1.0"?>
<!--
  AGV Simulation Robot Description (Gz Harmonic)

  All dimensions from src/agv_sim_description/config/robot_params.yaml
  Override via xacro args or launch parameters if needed.

  TF chain produced:
    base_link
      left_wheel     (continuous joint, driven by Gz DiffDrive)
      right_wheel    (continuous joint, driven by Gz DiffDrive)
      base_footprint (fixed, at ground level)
      zed_camera_link (fixed, at ZED 2i position)
           zed_camera_center
           zed_left_camera_frame, zed_right_camera_frame
           imu_link
      laser_frame    (fixed, front-mounted)
      front_caster   (fixed, for sim stability)
      rear_caster    (fixed, for sim stability)

  Gz Harmonic plugins:
    gz sim diff drive system (reads shaped_cmd_vel from drive shaping node)
    gz sim joint state publisher system (publishes joint states for robot_state_publisher)
    Sensors: depth_camera, camera, imu, gpu_lidar (bridged to ROS via ros_gz_bridge)
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="agv">

  <!-- Measured parameters (defaults from robot_params.yaml, 2026-03-18) -->
  <xacro:arg name="wheel_radius"  default="0.0625"/>
  <xacro:arg name="left_wheel_y"  default="0.3675"/>
  <xacro:arg name="right_wheel_y" default="-0.3675"/>
  <xacro:arg name="wheel_z"       default="-0.1375"/>
  <xacro:arg name="wheel_width"   default="0.05"/>

  <!-- Include components -->
  <xacro:include filename="$(find agv_sim_description)/urdf/agv_base_sim.xacro"/>
  <xacro:include filename="$(find agv_sim_description)/urdf/wheel_sim.xacro"/>
  <xacro:include filename="$(find agv_sim_description)/urdf/sensors_sim.xacro"/>

  <!-- Left wheel -->
  <xacro:wheel
    name="left"
    x="0"
    y="$(arg left_wheel_y)"
    z="$(arg wheel_z)"
    radius="$(arg wheel_radius)"
    width="$(arg wheel_width)"/>

  <!-- Right wheel -->
  <xacro:wheel
    name="right"
    x="0"
    y="$(arg right_wheel_y)"
    z="$(arg wheel_z)"
    radius="$(arg wheel_radius)"
    width="$(arg wheel_width)"/>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!--  Gz Harmonic Diff-Drive Plugin                         -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <!-- Joints -->
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>

      <!-- Kinematics -->
      <wheel_separation>0.735</wheel_separation>
      <wheel_radius>0.0625</wheel_radius>

      <!-- Topics (Gz Transport — bridged to ROS via ros_gz_bridge) -->
      <topic>/agv/shaped_cmd_vel</topic>
      <odom_topic>/agv/wheel_odom</odom_topic>
      <tf_topic>/agv/tf</tf_topic>

      <!-- Frames -->
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>

      <!-- Rate -->
      <odom_publish_frequency>50</odom_publish_frequency>
    </plugin>
  </gazebo>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!--  Joint State Publisher (for wheel TF via robot_state_publisher) -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <topic>/agv/joint_states</topic>
    </plugin>
  </gazebo>

</robot>
