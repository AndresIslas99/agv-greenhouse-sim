<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="wheel" params="name x y z radius width">
    <link name="${name}_wheel">
      <visual>
        <geometry>
          <cylinder radius="${radius}" length="${width}"/>
        </geometry>
        <material name="wheel_black">
          <color rgba="0.1 0.1 0.1 1.0"/>
        </material>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="${radius}" length="${width}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="2.0"/>
        <inertia ixx="${(1.0/12.0)*2.0*(3.0*radius*radius + width*width)}"
                 ixy="0" ixz="0"
                 iyy="${(1.0/12.0)*2.0*(3.0*radius*radius + width*width)}"
                 iyz="0"
                 izz="${0.5*2.0*radius*radius}"/>
      </inertial>
    </link>

    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}_wheel"/>
      <origin xyz="${x} ${y} ${z}" rpy="${-pi/2} 0 0"/>
      <axis xyz="0 0 1"/>
    </joint>

    <gazebo reference="${name}_wheel">
      <mu1>1.0</mu1>
      <mu2>1.0</mu2>
      <kp>1000000.0</kp>
      <kd>100.0</kd>
      <visual>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
          <specular>0.2 0.2 0.2 1</specular>
          <pbr><metal><metalness>0.0</metalness><roughness>0.9</roughness></metal></pbr>
        </material>
      </visual>
    </gazebo>
  </xacro:macro>

</robot>
